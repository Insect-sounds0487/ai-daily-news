{
  "name": "ai-daily-news",
  "version": "1.0.0",
  "private": true,
  "description": "AI行业每日大事总结 - 自动化日报生成器",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:light": "tsx src/index.ts --mode=light",
    "dev:deep": "tsx src/index.ts --mode=deep",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:light": "node dist/index.js --mode=light",
    "start:deep": "node dist/index.js --mode=deep",
    "setup-fonts": "tsx scripts/download-fonts.ts",
    "setup": "tsx scripts/setup.ts",
    "deploy": "tsx _deploy.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "marked": "^15.0.7",
    "openai": "^6.37.0",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3"
  }
}
