# === 必填 ===

# DeepSeek API Key（https://platform.deepseek.com/api_keys）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# === 可选 ===

# 日报模式: light | standard | deep (默认 standard)
REPORT_MODE=standard

# Playwright 浏览器路径（仅本地开发需要）
# 生产环境 Docker 镜像内置浏览器，不需要设置
PLAYWRIGHT_BROWSERS_PATH=E:/Insect-sounds/new/ms-playwright

# PushPlus Token（推送到微信，选填）
PUSHPLUS_TOKEN=3d8b56c334e84a27bf7254006aeddf7a

# 企业微信机器人 Webhook Key（推送到企业微信，选填；与 PushPlus 二选一或同时使用）
WECOM_WEBHOOK_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
